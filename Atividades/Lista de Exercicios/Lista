CREATE TABLE cursos (
    id INTEGER PRIMARY KEY,
    nome VARCHAR(50)
);

CREATE TABLE alunos (
    id INTEGER PRIMARY KEY,
    nome VARCHAR(50),
    idade INTEGER,
    id_curso INTEGER,
    FOREIGN KEY (id_curso) REFERENCES cursos(id)
);

